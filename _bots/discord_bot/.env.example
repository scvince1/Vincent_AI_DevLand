# ============================================
# Kestrel Discord Bot 配置 — 复制为 .env 后填入真实值
# ============================================
# Copy this file to .env and fill in the token.
# On Mac:  cp .env.example .env && nano .env
# On PC:   copy .env.example .env

# Discord Bot Token (来自 https://discord.com/developers/applications)
# 绝不要把真 token 提交到 git.
DISCORD_TOKEN=your_kestrel_token_here

# 用户映射: Discord ID → KESTREL_USER 模式
# 格式: discord_id:mode,discord_id:mode
#
# Kestrel 目前单用户: 仅 vincent
# 示例: USER_MAP=783473213413523477:vincent
USER_MAP=783473213413523477:vincent

# Claude Agent SDK 的 cwd — Kestrel 运行时把 claude subprocess cwd 设这里
# Mac 默认 /Users/scvin/
# 如果 Mac 上有 Vincent_AI_DevLand clone, 改成那个路径:
#   KESTREL_CWD=/Users/scvin/Vincent_AI_DevLand
KESTREL_CWD=/Users/scvin

# Python 可执行路径 (仅 start_kestrel.command / .sh 用, bot.py 本身不读)
# Mac 常见位置:
#   /usr/local/bin/python3       (Intel Mac, Homebrew)
#   /opt/homebrew/bin/python3    (Apple Silicon, Homebrew)
#   /usr/bin/python3             (system Python, 通常太旧)
PYTHON_BIN=/usr/local/bin/python3
