# SharkNinja Consumer Sentiment Dashboard — Backend Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env with real credentials.

# -----------------------------------------------------------------------
# Scraper adapter selection
# -----------------------------------------------------------------------
# Controls which data source the backend uses.
# Supported values: csv (default), reddit, hn, cpsc, ucsd
SCRAPER_ADAPTER=csv

# -----------------------------------------------------------------------
# Reddit PRAW OAuth credentials (required when SCRAPER_ADAPTER=reddit)
# -----------------------------------------------------------------------
# Create an OAuth app at https://www.reddit.com/prefs/apps
# App type: "script" for personal use / "web app" for deployed use
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
# Descriptive user agent string — Reddit policy requires this
REDDIT_USER_AGENT=sharkninja-sentiment/1.0 (research demo; contact: your@email.com)

# -----------------------------------------------------------------------
# What-If Simulator LLM API key (required when using POST /api/simulate)
# -----------------------------------------------------------------------
# Use an OpenAI or Anthropic API key.
# The simulator endpoint (R4-P1-2) is the ONLY place LLM calls are made.
# The forecast endpoint (GET /api/products/{model}/forecast) does NOT use LLMs.
SIMULATION_LLM_API_KEY=your_llm_api_key_here
# Optional: specify which LLM provider to use ("openai" or "anthropic")
# SIMULATION_LLM_PROVIDER=openai
